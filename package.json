{
  "name": "migracrm-pro",
  "version": "1.1.1",
  "description": "Sistema de gestion para asesores migratorios - offline, base de datos local, WhatsApp y reportes",
  "main": "main.js",
  "author": "Elite Trading Group",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.etg.migracrmpro",
    "productName": "MigraCRM PRO",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "MigraCRM-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "neurysrl1998-arch",
        "repo": "migracrm-pro"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MigraCRM PRO",
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "icon.png"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.3"
  }
}
